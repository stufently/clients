#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_configure:
	npm ci --ignore-scripts

override_dh_auto_build:
	cd apps/cli && NODE_ENV=production npx webpack

override_dh_auto_test:
	node apps/cli/build/bw.js --version

override_dh_auto_install:
	# Install the webpack bundle + runtime node_modules
	mkdir -p debian/bitwarden-cli/usr/lib/bitwarden-cli
	cp -r apps/cli/build/* debian/bitwarden-cli/usr/lib/bitwarden-cli/
	# Copy production node_modules (webpack externalizes npm deps at runtime)
	# Use a temporary copy to prune dev dependencies
	cp -rL node_modules debian/bitwarden-cli/usr/lib/bitwarden-cli/node_modules
	# Remove devDependencies, tests, docs, source maps to save space
	cd debian/bitwarden-cli/usr/lib/bitwarden-cli && \
	  find node_modules -maxdepth 2 -name "package.json" -exec grep -l '"_development":true' {} \; | \
	    xargs -I{} dirname {} | xargs rm -rf 2>/dev/null || true
	find debian/bitwarden-cli/usr/lib/bitwarden-cli/node_modules \
	  \( -name "*.map" -o -name "*.ts" -not -name "*.d.ts" \
	     -o -name "test" -o -name "tests" -o -name "__tests__" \
	     -o -name "example" -o -name "examples" \
	     -o -name ".github" -o -name ".git" \) \
	  -exec rm -rf {} + 2>/dev/null || true
	# Aggressive prune: webpack bundle in bw.js already contains all business
	# logic; node_modules only provides CommonJS runtime modules webpack
	# externalized. Strip docs, type defs, build tooling, metadata.
	# KEEP: LICENSE/COPYING/NOTICE/AUTHORS — required by MIT/Apache/GPL terms.
	find debian/bitwarden-cli/usr/lib/bitwarden-cli/node_modules \
	  \( -iname "*.md" -o -iname "readme*" -o -iname "changelog*" \
	     -o -iname "history*" -o -iname "*.markdown" \
	     -o -name "*.d.ts" -o -name "*.d.mts" -o -name "*.d.cts" \
	     -o -name "*.flow" -o -name "*.coffee" \
	     -o -name ".eslintrc*" -o -name ".prettierrc*" -o -name ".babelrc*" \
	     -o -name ".editorconfig" -o -name ".npmignore" -o -name ".gitignore" \
	     -o -name ".gitattributes" -o -name ".travis.yml" -o -name ".nvmrc" \
	     -o -name "tsconfig*.json" -o -name ".prettierignore" \
	     -o -name "*.ps1" -o -name "*.bat" -o -name "*.cmd" \
	     -o -name "Makefile" -o -name "bower.json" -o -name "component.json" \
	     -o -name "yarn.lock" -o -name "package-lock.json" \) \
	  -type f -delete 2>/dev/null || true
	find debian/bitwarden-cli/usr/lib/bitwarden-cli/node_modules \
	  -type d \
	  \( -name "types" -o -name "@types" -o -name "docs" -o -name "doc" \
	     -o -name "man" -o -name "benchmark" -o -name "benchmarks" \
	     -o -name "coverage" -o -name ".bin" \) \
	  -exec rm -rf {} + 2>/dev/null || true
	# Remove cross-arch prebuilt binaries (cause dh_strip failures)
	rm -rf debian/bitwarden-cli/usr/lib/bitwarden-cli/node_modules/7zip-bin 2>/dev/null || true
	# Keep only linux-x64 sass-embedded native binaries
	find debian/bitwarden-cli/usr/lib/bitwarden-cli/node_modules -maxdepth 2 -type d -name "sass-embedded-*" \
	  ! -name "sass-embedded-linux-x64" ! -name "sass-embedded-linux-musl-x64" \
	  -exec rm -rf {} + 2>/dev/null || true
	# Install launcher script
	mkdir -p debian/bitwarden-cli/usr/bin
	echo '#!/bin/sh' > debian/bitwarden-cli/usr/bin/bw
	echo 'exec /usr/bin/node --no-deprecation /usr/lib/bitwarden-cli/bw.js "$$@"' >> debian/bitwarden-cli/usr/bin/bw
	chmod 755 debian/bitwarden-cli/usr/bin/bw
	# Install man page
	mkdir -p debian/bitwarden-cli/usr/share/man/man1
	install -m 644 debian/bw.1 debian/bitwarden-cli/usr/share/man/man1/bw.1
	# Install bash completion
	mkdir -p debian/bitwarden-cli/usr/share/bash-completion/completions
	install -m 644 debian/bw.bash-completion debian/bitwarden-cli/usr/share/bash-completion/completions/bw
	# Install zsh completion
	mkdir -p debian/bitwarden-cli/usr/share/zsh/vendor-completions
	install -m 644 debian/bw.zsh-completion debian/bitwarden-cli/usr/share/zsh/vendor-completions/_bw

override_dh_strip:
	# Skip stripping — node_modules contains cross-arch binaries (7zip-bin)
	# and no native ELF objects that benefit from stripping

override_dh_shlibdeps:
	# Skip shared lib deps check — pure JS application with no native libs

override_dh_auto_clean:
	rm -rf apps/cli/build
