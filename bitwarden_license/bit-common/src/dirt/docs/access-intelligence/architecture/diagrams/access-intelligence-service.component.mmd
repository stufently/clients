    subgraph SERVICES["Access Intelligence Services [Container: Angular + TypeScript]"]
        direction TB
        AI_DATA["Access Intelligence Data Service
[Component: Angular Service]<br/>
Coordinates report generation and persistence; provides report data to UI components"]
        REPORT_GEN["Report Generation Component
[Component: Angular Service]<br/>
Builds the full access report from vault data, password health, and member access"]
        PERSIST["Report Persistence Component
[Component: Angular Service]<br/>
Saves and loads the report across the API and cloud storage"]
        SECURITY_TASKS["Security Tasks Service
[Component: Angular Service]<br/>
Creates and loads security tasks for at-risk credentials"]
    end

    VAULT_TEAM["Admin Task Service
[Component: Angular Service, Vault Team]<br/>
Vault team service for creating bulk security tasks"]

    BW_PLATFORM["Bitwarden Platform Services
[Component: Angular Services, Bitwarden Platform]<br/>
Core platform services for vault data, password health, and org membership"]

    HIBP["Have I Been Pwned
[Software System: External]<br/>
Checks passwords against breach database"]

    BW_SERVER["Bitwarden Server
[Container: .NET API]<br/>
API endpoints for report metadata and security tasks"]

    BLOBSTORE["Blob Storage
[Container: Azure Blob Storage]<br/>
Stores encrypted report files for large organizations"]

